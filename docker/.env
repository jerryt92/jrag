COMPOSE_PROJECT_NAME=jrag
TAG=1.0.0
JAVA_OPTS="-Xms2g -Xmx4g -XX:+UseG1GC -XX:MaxGCPauseMillis=200 -XX:MetaspaceSize=128m -XX:MaxMetaspaceSize=256m -XX:+HeapDumpOnOutOfMemoryError -Dfile.encoding=utf-8 -XX:HeapDumpPath=/opt/ai-center/logs/ai-center.hprof"
SPRING_OPTIONS="--spring.profiles.active=product,sqlite"
# Windows用户需修以下配置
JRAG_BASE_PATH=${HOME}/jrag
DIR_PATH_SEPARATOR=/